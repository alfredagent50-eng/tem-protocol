# Public API URL used by the Vite web app
VITE_TEM_API_URL=http://localhost:8787

# Host dashboard token is entered in the browser when opening host mode.
# The matching server-side secret lives in apps/api/.env.example as TEM_HOST_TOKEN.

# Future real Stripe checkout UI.
# The API can already create Stripe PaymentIntents when STRIPE_SECRET_KEY is configured.
# Add this when mounting Stripe Payment Element in the web app.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
