# Optional MVP host dashboard token.
# If set, PATCH /requests/:id/status requires Authorization: Bearer <token>.
TEM_HOST_TOKEN=change-me

# Payment provider selection.
# mock = simulated checkout for MVP demos.
# stripe = real Stripe PaymentIntents; requires a supported Stripe business account.
# grow/payplus/tranzila/allpay = placeholders for Israel/local PSP evaluation.
PAYMENT_PROVIDER=mock

# Optional Stripe skeleton.
# If PAYMENT_PROVIDER=stripe, /payment-intents creates real Stripe PaymentIntents.
STRIPE_SECRET_KEY=sk_test_...
